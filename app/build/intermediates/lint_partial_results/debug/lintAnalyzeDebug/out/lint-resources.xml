http://schemas.android.com/apk/res-auto;;${\:app*debug*MAIN*sourceProvider*0*resDir*0}/drawable/ic_launcher.xml,${\:app*debug*MAIN*sourceProvider*0*resDir*0}/values/strings.xml,${\:app*debug*MAIN*sourceProvider*0*resDir*0}/values/styles.xml,${\:app*debug*MAIN*sourceProvider*0*resDir*0}/xml/device_admin.xml,${\:app*debug*MAIN*sourceProvider*0*resDir*0}/xml/data_extraction_rules.xml,${\:app*debug*MAIN*sourceProvider*0*resDir*0}/xml/backup_rules.xml,${\:app*debug*MAIN*sourceProvider*0*resDir*0}/xml/whatsapp_guard_accessibility.xml,+drawable:ic_launcher,0,F;+string:enable_device_admin,1,V4000803f0,510008043d,;"Attiva amministratore dispositivo";status_device_admin_disabled,1,V4000f06ce,5f000f0729,;"Amministratore dispositivo\: non attivo";device_admin_explanation,1,V4001207cd,820012084b,;"Serve per ridurre disattivazioni accidentali dalle impostazioni del telefono.";device_admin_description,1,V4001b0c00,92001b0c8e,;"Riduce le disattivazioni accidentali e consente protezioni ufficiali sui dispositivi gestiti.";open_accessibility_settings,1,V400040122,5700040175,;"Apri impostazioni accessibilita";status_device_admin_enabled,1,V4000e0673,5a000e06c9,;"Amministratore dispositivo\: attivo";device_admin_disabled_toast,1,V4001709da,6100170a37,;"WhatsApp Guard amministratore disattivato";accessibility_service_label,1,V400190ad0,4600190b12,;"WhatsApp Guard";main_description,1,V40003006b,b60003011d,;"Blocca solo alcuni controlli di WhatsApp usando un servizio di accessibilita attivato su consenso utente. Non legge e non salva messaggi.";accessibility_service_description,1,V4001a0b17,e8001a0bfb,;"Servizio attivato su consenso utente per coprire solo controlli selezionati di WhatsApp. Non legge messaggi\, non invia contenuti e non cambia impostazioni senza consenso.";device_admin_enabled_toast,1,V40016097e,5b001609d5,;"WhatsApp Guard amministratore attivo";managed_protection_error,1,V400150929,5400150979,;"Errore protezioni gestite\: %1$s";device_admin_disable_warning,1,V400180a3c,9300180acb,;"Disattivando questo controllo WhatsApp Guard non potra piu proteggere i pulsanti bloccati.";open_android_app_info,1,V4000a0493,42000a04d1,;"Info app Android";accessibility_disclosure_title,1,V40005017a,51000501c7,;"Consenso accessibilita";status_accessibility_enabled,1,V4000c05d0,4e000c061a,;"Accessibilita\: attiva";accessibility_disclosure_message,1,V4000601cc,1d000060398,;"WhatsApp Guard usa il servizio di accessibilita solo quando WhatsApp e aperto. Legge elementi visibili dell'interfaccia\, come identificatori\, testo\, descrizioni e posizione dei controlli\, per coprire pulsanti selezionati. Non salva messaggi\, non invia contenuti\, non clicca al posto tuo e non cambia impostazioni senza consenso. Puoi disattivare il servizio dalle impostazioni Accessibilita di Android.";apply_managed_protection,1,V400090442,500009048e,;"Protezione avanzata gestita";app_name,1,V400020037,3300020066,;"WhatsApp Guard";status_managed_disabled,1,V40011077b,51001107c8,;"Gestione avanzata\: non attiva";managed_protection_requires_owner,1,V400130850,83001308cf,;"Queste protezioni richiedono configurazione gestita MDM/device owner.";accessibility_disclosure_accept,1,V40007039d,52000703eb,;"Ho capito e acconsento";status_accessibility_disabled,1,V4000d061f,53000d066e,;"Accessibilita\: non attiva";status_managed_enabled,1,V40010072e,4c00100776,;"Gestione avanzata\: attiva";main_note,1,V4000b04d6,f9000b05cb,;"Nota\: questa app funziona come APK generica su Android. La protezione avanzata e opzionale e richiede configurazione ufficiale MDM/device owner sul singolo telefono\; non usa codice specifico per marca o modello.";managed_protection_applied,1,V4001408d4,5400140924,;"Protezioni gestite applicate.";+style:AppTheme,2,V400020037,c0006013e,;D@android\:style/Theme.Material.Light.NoActionBar,android\:fontFamily:sans,android\:windowLightStatusBar:true,android\:colorAccent:#1FA855,;+xml:device_admin,3,F;data_extraction_rules,4,F;backup_rules,5,F;whatsapp_guard_accessibility,6,F;